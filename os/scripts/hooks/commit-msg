#!/usr/bin/env bash
# commit-msg — Plainframe protected-path gate (law 7), enforced at the git
# level so a raw `git commit` cannot bypass sync.sh's check (PF-003b).
#
# Blocks a commit that touches a protected path (see os/scripts/lib/guard.sh)
# unless the commit message has OWNER-CONFIRMED as its own line — trimmed of
# surrounding whitespace, it IS the whole line, nothing else. A mention, a
# prefix ("OWNER-CONFIRMED: ..."), or a negation ("this is NOT
# OWNER-CONFIRMED yet") never counts (PF-003a, hardened by adversarial
# review past an earlier word-boundary-substring rule that a negation could
# still slip through). os/decisions.md is special-cased: a pure append of
# new entries passes without the token (agents draft, the owner enacts — law
# 7); any edit to an existing line, or a new entry that already claims
# "**Status:** confirmed", needs the token (PF-005).
#
# Wired by the same core.hooksPath as pre-commit: os/scripts/doctor.sh --setup
# Bypass once (owner's call): git commit --no-verify — break-glass only,
# never routine; it skips this gate entirely and leaves no trace that it did.

set -eu
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

MSG_FILE=${1:-}
if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  echo "commit-msg: no commit message file given — refusing to guess (internal error)" >&2
  exit 2
fi
MSG=$(cat "$MSG_FILE")

TMP=$(mktemp -d "${TMPDIR:-/tmp}/commit-msg.XXXXXX")
trap 'rm -rf "$TMP"' EXIT

# shellcheck source=../lib/guard.sh
. "$ROOT/os/scripts/lib/guard.sh"

if owner_confirmed "$MSG"; then
  exit 0
fi

: > "$TMP/prot"
# shellcheck disable=SC2086
git diff --cached --name-only -- $PROTECTED_PATHS >> "$TMP/prot" || true
if [ -n "$(git diff --cached --name-only -- os/decisions.md)" ]; then
  OLD_LEDGER="$TMP/ledger-old"
  if git cat-file -e HEAD:os/decisions.md 2>/dev/null; then
    git show HEAD:os/decisions.md > "$OLD_LEDGER"
  else
    : > "$OLD_LEDGER"
  fi
  NEW_LEDGER="$TMP/ledger-new"
  if git cat-file -e :os/decisions.md 2>/dev/null; then
    git show :os/decisions.md > "$NEW_LEDGER"
  else
    : > "$NEW_LEDGER"
  fi
  if ! ledger_append_only "$OLD_LEDGER" "$NEW_LEDGER"; then
    echo "os/decisions.md" >> "$TMP/prot"
  fi
fi

if [ -s "$TMP/prot" ]; then
  echo "BLOCKED: this commit touches protected path(s) (law 7 — agents draft, the owner enacts):" >&2
  sed 's/^/  /' "$TMP/prot" >&2
  echo "OWNER-CONFIRMED is an owner-only token — only the owner can approve this in-session." >&2
  cat >&2 <<'EOF'
With the owner's explicit in-session yes, make OWNER-CONFIRMED its own line
in the commit message (trimmed of surrounding whitespace) — a mention,
prefix, or negation elsewhere in the message never counts. Example:
  <commit message>
OWNER-CONFIRMED
EOF
  exit 1
fi
exit 0
