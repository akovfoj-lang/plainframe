# Secrets: values live in .env; only names are committed, in .env.example.
# .env* covers the whole dotenv family (.env.local, .env.production,
# .env.development, .env.bak, etc.) — a bare `.env` line only ever matched
# that one exact filename and silently let every variant through.
# .env.example must stay tracked, so it is un-ignored right after.
.env*
!.env.example

# macOS noise.
.DS_Store

# Anything meant for this machine only.
*.local.*

# Works fine with Obsidian — just keep its plugins and workspace state out of git.
.obsidian/

# Satellites own code, but just in case something gets installed here.
node_modules/

# Credential shapes an integration can drop on disk — belt and braces; real
# values live in .env or the password manager, never in git.
*.pem
*.key
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*
*credentials*.json
*service-account*.json
*-key.json
.netrc
.npmrc
*.db
*.sqlite
